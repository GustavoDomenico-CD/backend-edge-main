generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  password       String
  name           String?
  avatarUrl      String?
  phone          String?
  role           String           @default("user")
  permissions    Json             @default("[]")
  isActive       Boolean          @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  proactiveRules ProactiveRule[]
}

/// Regra de comportamento proativo do agente.
/// O agente pode enviar mensagens automaticamente com base em triggers configurados.
model ProactiveRule {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Tipo do trigger: "interval" | "event" | "schedule"
  trigger     String
  /// Condição em JSON (ex.: { "intervalMinutes": 30 } ou { "event": "new_appointment" })
  condition   Json
  /// Mensagem ou template que o agente envia proativamente
  message     String
  /// Se a regra está ativa
  isActive    Boolean  @default(true)
  /// Última vez que esta regra foi disparada
  lastFiredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
