generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  username       String?          @unique
  password       String
  name           String?
  avatarUrl      String?
  phone          String?
  role           String           @default("user")
  permissions    Json             @default("[]")
  isActive       Boolean          @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  proactiveRules ProactiveRule[]
  chatbotCadastro ChatbotCadastro?
}

/// Cadastro de paciente feito pelo fluxo do chatbot (auditoria + vínculo com User).
model ChatbotCadastro {
  id                   Int      @id @default(autoincrement())
  email                String
  name                 String?
  phone                String?
  consultationType     String?
  consultationCategory String?
  role                 String   @default("paciente")
  userId               Int?     @unique
  user                 User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  status               String   @default("pending")
  errorMessage         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

/// Regra de comportamento proativo do agente.
/// O agente pode enviar mensagens automaticamente com base em triggers configurados.
model ProactiveRule {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Tipo do trigger: "interval" | "event" | "schedule"
  trigger     String
  /// Condição em JSON (ex.: { "intervalMinutes": 30 } ou { "event": "new_appointment" })
  condition   Json
  /// Mensagem ou template que o agente envia proativamente
  message     String
  /// Se a regra está ativa
  isActive    Boolean  @default(true)
  /// Última vez que esta regra foi disparada
  lastFiredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── WhatsApp Integration ─────────────────────────────────

model WhatsAppConfig {
  id           Int      @id @default(autoincrement())
  instanceName String   @default("default")
  phoneNumber  String   @default("")
  /// Legado (Cloud API). Com Baileys + QR fica vazio.
  apiKey       String   @default("")
  webhookUrl   String   @default("")
  status       String   @default("disconnected")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WhatsAppContact {
  id            Int                @id @default(autoincrement())
  phoneNumber   String             @unique
  name          String
  profilePicUrl String?
  isBlocked     Boolean            @default(false)
  /// Se o agente AI deve responder automaticamente a este contato
  agentEnabled  Boolean            @default(true)
  lastMessageAt DateTime?
  tags          String             @default("[]")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  messages      WhatsAppMessage[]
}

model WhatsAppMessage {
  id           Int              @id @default(autoincrement())
  contactId    Int
  contact      WhatsAppContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  direction    String
  type         String
  content      String
  mediaUrl     String?
  status       String           @default("pending")
  externalId   String?
  templateName String?
  sentAt       DateTime
  deliveredAt  DateTime?
  readAt       DateTime?
  createdAt    DateTime         @default(now())
}

model WhatsAppTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  language  String
  content   String
  variables String   @default("[]")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Log de envios automáticos pós-consulta (receita/prontuário via WhatsApp).
model ConsultationWhatsAppLog {
  id            Int      @id @default(autoincrement())
  appointmentId String
  patientPhone  String
  patientName   String?
  status        String
  partsSent     Int      @default(0)
  error         String?
  createdAt     DateTime @default(now())
}
