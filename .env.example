# Evita conflito com Next.js na porta 3000
PORT=3001

# Prisma (SQLite neste projeto)
DATABASE_URL="file:./dev.db"
JWT_SECRET=change-me-in-production

# CORS: origem do front local
FRONTEND_URL=http://localhost:3000

# WhatsApp (Baileys / libsignal)
# Se aparecer "Bad MAC" ou "Failed to decrypt message with any known session":
# 1) Pare o backend; 2) apague a pasta .wa_sessions/<instancia> (ou use POST /admin/whatsapp/reset-session);
# 3) suba de novo e escaneie o QR. Rode apenas UMA instância do backend por vez.
# Opcional: WA_SIGNAL_KEY_CACHE=1 — cache de chaves Signal (pode ser mais rápido; em alguns ambientes causa dessincronia)
# WA_SIGNAL_KEY_CACHE=
